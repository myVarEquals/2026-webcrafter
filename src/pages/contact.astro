---
import BaseLayout from '../layouts/BaseLayout.astro';

const titleTag = "Contact Us";
const metaDescription = "Have a question? Reach out to us.";
---

<BaseLayout titleTag={titleTag} metaDescription={metaDescription}>
  <h1>Contact Us</h1>
  <form action="/actions/send-email" method="post">
      <div>
        <label for="send-email__recipient">To:</label>
        <input class="border" type="email" name="recipient" id="send-email__recipient" required />
      </div>
      <div>
        <label for="send-email__subject">Subject:</label>
        <input class="border" type="text" name="subject" id="send-email__subject" required />
      </div>
      <div>
        <label for="send-email__message">Message:</label>
        <textarea class="border" name="message" id="send-email__message" required></textarea>
      </div>
      <input class="border" type="submit" value="Send message" />
    </form>
</BaseLayout>
