---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import { Image } from 'astro:assets';
import takeOff from '../images/take-off.png'
import puzzlePiece from '../images/men-carrying-puzzle.jpg'
import Testimonial from '../components/Testimonial.astro';

const titleTag = "SEO Optimized Web Design and Development";
const metaDescription = "Rank better on search engines with tech that loads fast";

---
<BaseLayout titleTag={titleTag} metaDescription={metaDescription}>

	<div class="bg-(--wc-blue) flex flex-col w-full md:min-h-150">

		<div class="flex flex-col md:flex-row w-full max-w-400 m-auto">

			<div class="w-full md:w-1/2 flex flex-col justify-center p-8">

				<h1 class="font-sans text-lg text-white max-w-150">SEO Optimized Web Design and Development</h1>
				<p class="font-sans text-3xl md:text-4xl lg:text-6xl text-white max-w-150">Use the right tools to get your business ranking on Google</p>

			</div>

			<div class="hidden md:w-1/2 md:flex flex-col justify-center items-center p-8">
				<Image src={takeOff} alt="A rocket taking off" class="w-4/5 bg-white p-8 rounded-[50px] rounded-tl-[50%]" />
			</div>
		</div>
		

	</div>

	<div class="bg-white flex flex-col w-full md:min-h-150">

		<TestimonialSection />

	</div>

		<div class="bg-white flex flex-col w-full md:min-h-150">

		<div class="flex flex-col md:flex-row w-full max-w-400 m-auto">

			<div class="hidden md:w-1/2 md:flex flex-col justify-center items-center p-8">
				<Image src={puzzlePiece} alt="Men carrying a puzzle" class="w-4/5 bg-white" />
			</div>

			<div class="w-full md:w-1/2 flex flex-col gap-6 justify-center p-8">
				<h2 class="font-sans text-2xl md:text-4xl text-(--wc-blue) max-w-150">We Create Stunning Websites that Improve Conversions</h2>
				<p class="font-sans text-xl text-black max-w-150">Most of modern day internet traffic is on mobile devices. If your website isn’t mobile responsive, you may be losing potential clients!</p>
				<a class="self-start font-sans text-xl text-white bg-(--wc-blue) hover:bg-(--wc-dark-blue) py-2 px-4 rounded" href="/about/">Learn More</a>
			</div>
			
		</div>		

	</div>

	

</BaseLayout>