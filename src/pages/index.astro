---
import BaseLayout from '../layouts/BaseLayout.astro';
import Greeting from '../components/Greeting';
import { Image } from 'astro:assets';
import takeOff from '../images/take-off.png'

const titleTag = "SEO Optimized Web Design and Development";
const metaDescription = "Rank better on search engines with tech that loads fast";

---
<BaseLayout titleTag={titleTag} metaDescription={metaDescription}>

	<div class="bg-(--wc-blue) flex flex-col w-full">

		<div class="flex flex-row w-full max-w-400 m-auto">
			<div class="w-1/2 flex flex-col justify-center p-8">
				<h1 class="font-sans text-lg text-white">SEO Optimized Web Design and Development</h1>
				<p class="font-sans text-7xl text-white">Use the right tools to get your business ranking on Google</p>
			</div>

			<div class="w-1/2 flex flex-col justify-center items-center p-8">
				<Image src={takeOff} alt="A rocket taking off" class="w-3/5 bg-white p-8 rounded-[50px] rounded-tl-[50%]" />
			</div>
		</div>
		<div class="hero-divider"></div>

	</div>

	<Greeting client:load messages={["Hej", "Hallo", "Hola", "Habari"]} />

</BaseLayout>