---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import puzzlePiece from '../images/men-carrying-puzzle.jpg'

const titleTag = "Thank You";
const metaDescription = "Thank you for reaching out to us. We will get back to you shortly.";
---

<BaseLayout titleTag={titleTag} metaDescription={metaDescription}>
  	<div class="bg-white flex flex-col w-full md:min-h-150">

		<div class="flex flex-col md:flex-row w-full max-w-400 m-auto">

			<div class="w-full md:w-1/2 flex flex-col gap-6 justify-center p-8">
				<h2 class="font-sans text-2xl md:text-4xl text-(--wc-blue) max-w-150">Thank You</h2>
				<p class="font-sans text-xl text-black max-w-150">Thank you for reaching out to us. We will get back to you shortly.</p>
				<a class="self-start font-sans text-xl text-white bg-(--wc-blue) hover:bg-(--dk-blue) py-2 px-4 rounded" href="/">Return to Homepage</a>
			</div>

      <div class="hidden md:w-1/2 md:flex flex-col justify-center items-center p-8">
				<Image src={puzzlePiece} alt="Men carrying a puzzle" class="w-4/5 bg-white" />
			</div>
			
		</div>		

	</div>
</BaseLayout>
