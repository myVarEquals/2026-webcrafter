---
const { question, answer } = Astro.props;
---

<div class="toggle-wrapper flex flex-col">
    <div class="toggle-header flex flex-row justify-between items-center gap-4" role="button" aria-expanded="false">
        <h3 class="font-sans text-2xl">{question}</h3>
        <div class="toggle-icons">
            <i class="toggle-closed fa-solid fa-plus"></i>
            <i class="toggle-opened fa-solid fa-minus"></i>
        </div>    
    </div>
    <div class="toggle-content">
        <p class="font-sans pt-3">{answer}</p>
    </div>
</div>
<hr>