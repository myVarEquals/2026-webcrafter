---
const { url, title, description, tags } = Astro.props;
---

<li class="bg-white w-full lg:w-1/4 lg:max-w-123 grow flex flex-col gap-8 justify-start p-12 border-3 border-(--wc-blue) rounded-2xl shadow-xl">
    <div class="flex flex-row flex-wrap gap-4">
        {tags.map((tag: any) => (
            <a class="p-4 rounded-xl text-sm text-white bg-(--dk-blue)" href={`/tags/${tag}`}>{tag}</a>
        ))}
    </div>
    <a class="text-2xl" href={url}>{title}</a>
    <p class="font-sans text-xl text-black">"{description}"</p>

</li>
